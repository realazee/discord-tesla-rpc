# Tesla Fleet API — register at https://developer.tesla.com
TESLA_CLIENT_ID=your_tesla_client_id
TESLA_CLIENT_SECRET=your_tesla_client_secret

# Region: na | eu | cn
TESLA_REGION=na

# Public domain for OAuth callback (Cloudflare Worker)
# The worker bounces the callback to localhost:8888
CALLBACK_DOMAIN=https://tesla-rpc.yourdomain.com

# Discord — create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id
