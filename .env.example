# Tesla Fleet API — register at https://developer.tesla.com
TESLA_CLIENT_ID=your_tesla_client_id
TESLA_CLIENT_SECRET=your_tesla_client_secret

# Region: na | eu | cn
TESLA_REGION=na

# Public domain for OAuth callback (Cloudflare Worker)
# The worker bounces the callback to localhost:8888
CALLBACK_DOMAIN=https://tesla-rpc.yourdomain.com

# Discord — create app at https://discord.com/developers/applications
DISCORD_CLIENT_ID=your_discord_client_id

# (Optional) Specific vehicle VIN — leave empty to auto-select first vehicle
TESLA_VIN=

# (Optional) Speed / distance: mph | kph
SPEED_UNITS=mph

# (Optional) Temperature: F | C
TEMP_UNITS=F

# (Optional) Disable specific metrics (comma-separated)
# Available: speed, street, location, gear, battery, range, charging,
#            insideTemp, outsideTemp, odometer, sentry
# DISABLE_METRICS=odometer,sentry
